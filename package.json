{
  "name": "avaxopoly",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "build": "pnpm -r build",
    "dev:server": "pnpm --filter @avaxopoly/server dev",
    "dev:web": "pnpm --filter @avaxopoly/web dev",
    "test": "pnpm -r test",
    "prepare": "husky",
    "security:deps": "XDG_DATA_HOME=${XDG_DATA_HOME:-$PWD/.socket-data} pnpm exec socket ci"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "socket": "^1.1.68"
  }
}
